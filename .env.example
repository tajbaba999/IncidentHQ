NODE_ENV=development
LOG_LEVEL=info
PORT=3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pulseping

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
SQS_QUEUE_URL=http://localhost:4566/000000000000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pulseping

CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
RESEND_API_KEY=re_xxx

NEXT_PUBLIC_APP_URL=http://localhost:3000

# saas = Vercel + Neon, health checks via Vercel Cron sweep
# selfhost = Docker + standard Postgres, in-process scheduler
DEPLOY_MODE=saas
# Required in saas mode: protects GET /api/cron/health-check (Vercel Cron sends it as a Bearer token)
CRON_SECRET=change-me

CORS_ORIGIN=http://localhost:3001