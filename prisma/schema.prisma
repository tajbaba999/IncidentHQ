// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =====================================
// USER (Clerk-backed)
// =====================================
model User {
  id           String        @id @default(cuid())
  clerkId      String        @unique
  email        String        @unique
  name         String?
  firstName    String?
  lastName     String?
  imageUrl     String?
  projects     Project[]
  alerts       Alert[]
  integrations Integration[]
  postmortems  Postmortem[]
  subscription Subscription?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// =====================================
// PROJECT
// =====================================
model Project {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  monitors    Monitor[]
  statusPage  StatusPage?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId])
}

// =====================================
// MONITOR
// =====================================
model Monitor {
  id              String           @id @default(cuid())
  projectId       String
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name            String
  url             String
  description     String?
  method          HttpMethod       @default(GET)
  expectedStatus  Int              @default(200)
  frequency       Int // interval in seconds
  isActive        Boolean          @default(true)
  alertEmail      String?
  authType        AuthType         @default(NONE)
  authData        Json?
  monitorRuns     MonitorRun[]
  alerts          Alert[]
  postmortems     Postmortem[]
  statusComponent StatusComponent?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([projectId])
  @@index([isActive])
}

// =====================================
// MONITOR RUN (Every interval execution)
// =====================================
model MonitorRun {
  id           String   @id @default(cuid())
  monitorId    String
  monitor      Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  statusCode   Int?
  responseTime Int? // milliseconds
  success      Boolean
  message      String?
  createdAt    DateTime @default(now())

  @@index([monitorId])
  @@index([createdAt])
  @@index([monitorId, createdAt])
}

// =====================================
// ALERT
// =====================================
model Alert {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  monitorId  String
  monitor    Monitor   @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  type       AlertType @default(EMAIL)
  message    String?
  resolved   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([userId])
  @@index([monitorId])
}

// =====================================
// INTEGRATIONS (Slack, Email, etc.)
// =====================================
model Integration {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      IntegrationType
  config    Json
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([userId, type])
  @@index([userId])
}

// =====================================
// SUBSCRIPTION / PLAN
// =====================================
model Subscription {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan            Plan     @default(FREE)
  status          String   @default("active")
  monitorsLimit   Int      @default(3)
  intervalSeconds Int      @default(60)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// =====================================
// POSTMORTEM
// =====================================
model Postmortem {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  monitorId     String
  monitor       Monitor          @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  title         String
  rootCause     String
  timeline      Json
  severity      Severity         @default(MINOR)
  status        PostmortemStatus @default(DRAFT)
  summary       String?
  resolution    String?
  writtenBy     String?
  incidentStart DateTime?
  incidentEnd   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([monitorId])
  @@index([userId])
}

// =====================================
// STATUS PAGE (public, incident.io-style)
// =====================================
model StatusPage {
  id          String             @id @default(cuid())
  projectId   String             @unique
  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  slug        String             @unique // validated /^[a-z0-9-]{3,50}$/ in API
  name        String
  description String?
  logoUrl     String?
  brandColor  String?
  isPublished Boolean            @default(false)
  groups      ComponentGroup[]
  incidents   Incident[]
  subscribers StatusSubscriber[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model ComponentGroup {
  id           String            @id @default(cuid())
  statusPageId String
  statusPage   StatusPage        @relation(fields: [statusPageId], references: [id], onDelete: Cascade)
  name         String
  displayOrder Int               @default(0)
  components   StatusComponent[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([statusPageId])
}

model StatusComponent {
  id           String              @id @default(cuid())
  groupId      String
  group        ComponentGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  monitorId    String              @unique
  monitor      Monitor             @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  displayName  String
  displayOrder Int                 @default(0)
  manualStatus ComponentStatus? // null = derive automatically from monitor runs
  incidents    IncidentComponent[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([groupId])
}

model Incident {
  id           String              @id @default(cuid())
  statusPageId String
  statusPage   StatusPage          @relation(fields: [statusPageId], references: [id], onDelete: Cascade)
  title        String
  severity     Severity?
  status       IncidentStatus      @default(INVESTIGATING)
  startedAt    DateTime            @default(now())
  resolvedAt   DateTime?
  updates      IncidentUpdate[]
  components   IncidentComponent[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([statusPageId])
  @@index([statusPageId, status])
}

model IncidentUpdate {
  id         String         @id @default(cuid())
  incidentId String
  incident   Incident       @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  status     IncidentStatus
  message    String
  createdAt  DateTime       @default(now())

  @@index([incidentId])
}

model IncidentComponent {
  incidentId  String
  incident    Incident        @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  componentId String
  component   StatusComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@id([incidentId, componentId])
  @@index([componentId])
}

model StatusSubscriber {
  id           String     @id @default(cuid())
  statusPageId String
  statusPage   StatusPage @relation(fields: [statusPageId], references: [id], onDelete: Cascade)
  email        String
  token        String     @unique @default(cuid()) // unsubscribe token
  verifiedAt   DateTime?
  createdAt    DateTime   @default(now())

  @@unique([statusPageId, email])
  @@index([statusPageId])
}

// =====================================
// ENUMS
// =====================================
enum ComponentStatus {
  OPERATIONAL
  DEGRADED
  DOWN
  MAINTENANCE
}

enum IncidentStatus {
  INVESTIGATING
  IDENTIFIED
  MONITORING
  RESOLVED
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}

enum AuthType {
  NONE
  HEADER
  BEARER
  BASIC
}

enum AlertType {
  EMAIL
  SLACK
}

enum IntegrationType {
  SLACK
  RESEND_EMAIL
}

enum Severity {
  CRITICAL
  MAJOR
  MINOR
}

enum PostmortemStatus {
  DRAFT
  PUBLISHED
}

enum Plan {
  FREE
  PRO
  TEAM
  ENTERPRISE
}
