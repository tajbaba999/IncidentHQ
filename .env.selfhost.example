# Self-hosted PulsePing configuration.
# Copy to .env.selfhost and fill in the values marked "required".

# --- Database (matches the postgres service in docker-compose.selfhost.yml) ---
# If you change POSTGRES_PASSWORD, keep DATABASE_URL in sync.
POSTGRES_PASSWORD=pulseping
DATABASE_URL=postgresql://pulseping:pulseping@postgres:5432/pulseping

# --- Auth (required) — bring your own free Clerk keys, see SELF_HOSTING.md ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# Clerk webhook signing secret (optional — only if you set up the user-sync webhook)
SVIX_SECRET=

# --- URLs ---
# The address users will reach this instance on (used in emails and links).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Email notifications (optional — leave empty to disable email alerts) ---
RESEND_API_KEY=

# --- Mode (leave as selfhost) ---
DEPLOY_MODE=selfhost
