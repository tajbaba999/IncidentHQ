{
  "name": "pulseping",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "libs/*",
    "services/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "pnpm --filter @pulseping/shared build && pnpm --filter @pulseping/api build && pnpm --filter @pulseping/worker build",
    "build:web": "next build",
    "start": "next start",
    "dev:api": "pnpm --filter @pulseping/api dev",
    "dev:worker": "pnpm --filter @pulseping/worker dev",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "next": "^16.2.4",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  },
  "dependencies": {
    "@clerk/nextjs": "^7.3.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.1.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "resend": "^6.12.2",
    "sonner": "^2.0.7",
    "svix": "^1.92.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0"
  }
}